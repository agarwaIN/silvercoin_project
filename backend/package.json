{
  "name": "silvercoin-backend",
  "version": "1.0.0",
  "description": "Loan management backend API",
  "main": "src/index.js",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon",
    "local:db": "node src/scripts/start-dynamo-local.js",
    "local:setup": "npm run dynamo:ensure-tables && npm run dynamo:seed",
    "dynamo:ensure-tables": "node src/scripts/ensure-dynamo-tables.js",
    "dynamo:seed": "node src/scripts/seed-superadmin.js"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.758.0",
    "@aws-sdk/lib-dynamodb": "^3.758.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-validator": "^7.1.0",
    "helmet": "^7.1.0",
    "js-yaml": "^4.1.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "dynalite": "^4.0.0",
    "nodemon": "^3.1.14"
  }
}
